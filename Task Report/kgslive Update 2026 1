	public function emailUpload(Request $request)
    {
        $request->validate([
            'file' => 'required|mimes:xlsx,xls',
            'month' => 'required|string',
            'year' => 'required|integer',
        ]);

        try {
            $file = $request->file('file');
            $data = Excel::toArray(new EmailImport, $file);

            $errors = [];
            foreach ($data[0] as $key => $row) {
                $email = $row['email'] ?? null;

                if (!$email || !filter_var($email, FILTER_VALIDATE_EMAIL)) {
                    $errors[] = "Invalid email on row " . ($key + 2);
                    continue;
                }

                $teamMember = Teammember::where('emailid', $email)->first();
                if (!$teamMember) {
                    $errors[] = "Email not found in teammembers on row " . ($key + 2);
                    continue;
                }

                DB::table('articlepayrolls')->insert([
                    'emailid' => $teamMember->id,
                    'entity' => $teamMember->entity,
                    'neftstatus' => 0,
                    'month' => $request->month,
                    'currentyear' => $request->year,
                    'created_at' => now(),
                    'updated_at' => now(),
                ]);
            }

            if (!empty($errors)) {
                return back()->withErrors($errors);
            }

            return back()->with('success', 'Email IDs uploaded successfully.');
        } catch (Exception $e) {
            DB::rollBack();
            Log::emergency("File:" . $e->getFile() . "Line:" . $e->getLine() . "Message:" . $e->getMessage());
            report($e);
            $output = array('msg' => $e->getMessage());
