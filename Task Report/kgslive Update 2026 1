        $(function() {
            function parsePayrollValue(selector) {
                var value = parseFloat($(selector).val());
                return isNaN(value) ? 0 : value;
            }

            function updateTotalAmountToPaid() {
                var monthlyGrossSalary = parsePayrollValue('#monthly_gross_salary');
                var totalDays = parsePayrollValue('#totaldays');
                var dayToBePaid = parsePayrollValue('#day_to_be_paid');
                var pfAmount = parsePayrollValue('#pfamount');
                var amount = 0;
                var total = 0;

                if (totalDays > 0) {
                    amount = (monthlyGrossSalary / totalDays) * dayToBePaid;
                }

                total = amount - pfAmount;

                $('#amount').val(amount.toFixed(2));
                $('#total_amount_to_paid').val(total.toFixed(2));
            }

            $('body').on('input', '#monthly_gross_salary, #totaldays, #day_to_be_paid, #pfamount',
                function() {
                    updateTotalAmountToPaid();
                });

            $('body').on('click', '#editCompany', function() {
