    public function employeepayroll_update(Request $request)
    {
        try {
            $existing = DB::table('employeepayrolls')->where('id', $request->id)->first();

            $newData = [
                'no_of_day_present' => $request->no_of_day_present,
                'sl' => $request->sl,
                'cl' => $request->cl,
                'co' => $request->co,
                'birthday' => $request->birthday,
                'day_to_be_paid' => $request->day_to_be_paid,
