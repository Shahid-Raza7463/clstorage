                                    responseType: 'blob'
                                },
                                success: function(data) {
                                    clearInterval(progressInterval);
                                    $('#loading-bar').css('width', '100%')
                                        .text('Downloading... 100%');

                                    let blob = new Blob([data], {
                                        type: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
