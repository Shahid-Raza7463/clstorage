                // 'employee_contribution' => $request->employee_contribution,
                // 'monthly_gross_salary' => $request->monthly_gross_salary,
            ];

            $isChanged = false;
            foreach ($newData as $key => $value) {
                if ($existing->$key != $value) {
                    $isChanged = true;
                    break;
                }
            }

            if (!$isChanged) {
                $output = array('msg' => 'No changes detected. Data was not updated.');
                return back()->with('statuss', $output);
            }

            // DB::table('employeepayrolls')->where('id', $request->id)->update($newData);
            DB::table('employeepayrolls')->where('id', $request->id)->update([
                'no_of_day_present' => $request->no_of_day_present,
                'sl' => $request->sl,
                'cl' => $request->cl,
                'co' => $request->co,
                'birthday' => $request->birthday,
                'day_to_be_paid' => $request->day_to_be_paid,
                'totaldays' => $request->totaldays,
                'absent' => $request->absent,
                'amount'  => $request->amount,
                'total_amount_to_paid'  => $request->total_amount_to_paid,
                'payroleaffect'  => 1,
                // 'monthly_gross_salary' => $request->monthly_gross_salary,
                // 'employee_contribution' => $request->employee_contribution,
            ]);

            $updatedPayroll = DB::table('employeepayrolls')->where('id', $request->id)->first();
            $actionName = class_basename($request->route()->getActionname());
            $pagename = substr($actionName, 0, strpos($actionName, "Controller"));
            $changes = [];
            foreach ($newData as $field => $value) {
                $oldValue = $existing->$field ?? null;
                $newValue = $updatedPayroll->$field ?? null;

                $normalizedOldValue = is_string($oldValue) ? trim($oldValue) : $oldValue;
                $normalizedNewValue = is_string($newValue) ? trim($newValue) : $newValue;

                if ($normalizedOldValue !== $normalizedNewValue) {
                    if ($normalizedOldValue === null || $normalizedOldValue === '') {
                        $changes[$field] = "($field is changed from null to $newValue)";
                    } else {
                        $changes[$field] = "($field is changed from $oldValue to $newValue)";
                    }
                }
            }

            $employeeName = DB::table('teammembers')
                ->where('id', $updatedPayroll->teammember_id)
                ->value('team_member');

            $description = "(Employee Name: " . ($employeeName ?? 'N/A') . ", Payroll ID: " . $request->id;
            if (!empty($changes)) {
                $description .= ", " . implode(', ', $changes);
            }
            $description .= ")";

            DB::table('activitylogs')->insert([
                'user_id' => auth()->user()->teammember_id,
                'teammember_id' => $updatedPayroll->teammember_id,
                'ip_address' => $request->ip(),
                'activitytitle' => $pagename,
                'month_year' => ($updatedPayroll->year ?? now()->format('Y')) . '-' .
                    Carbon::parse('1 ' . ($updatedPayroll->month ?? now()->format('F')))->format('m'),
                'generate_date_time' => now()->format('Y-m-d H:i:s'),
                'description' => substr($description, 0, 65535),
                'created_at' => now(),
                'updated_at' => now(),
            ]);

            return back()->with('success', 'Updated Successfully');
        } catch (Exception $e) {
            DB::rollBack();
            Log::emergency("File:" . $e->getFile() . "Line:" . $e->getLine() . "Message:" . $e->getMessage());
            report($e);
            return back()->withErrors(['msg' => $e->getMessage()])->withInput();
        }
    }






