	 public function checkinfiltersection(Request $request)
    {
        $employeeId = (int) $request->employeeid;
        $month = (int) $request->month;
        $fromDate = $request->fromdate;
        $toDate = $request->todate;
        $partnerid = $request->partnerid;

        if ($request->ajax()) {
            $query = DB::table('checkins')
                ->leftJoin('teammembers', 'teammembers.id', '=', 'checkins.teammember_id')
                ->leftJoin('clients', 'clients.id', '=', 'checkins.client_id')
                ->leftJoin('assignmentbudgetings', 'assignmentbudgetings.assignmentgenerate_id', '=', 'checkins.assignment_id')
                ->leftJoin('assignments', 'assignments.id', '=', 'assignmentbudgetings.assignment_id')
                ->leftJoin('assignmentmappings', 'assignmentmappings.assignmentgenerate_id', '=', 'checkins.assignment_id')
                ->leftJoin('teammembers as teampartner', 'teampartner.id', '=', 'assignmentmappings.leadpartner')
                ->when($employeeId, function ($query) use ($employeeId) {
                    return $query->where('checkins.teammember_id', $employeeId);
                })
                ->when($month, function ($query) use ($month) {
                    return $query->whereMonth('checkins.created_at', $month);
                })
                ->when($request->yearly != 0, function ($query) use ($request) {
                    return $query->whereYear('checkins.created_at', $request->yearly);
                })
                ->when($request->checkin != null, function ($query) use ($request) {
                    return $query->where('checkins.checkin_from', $request->checkin);
                })
                ->when($request->type != null, function ($query) use ($request) {
                    return $query->where('checkins.typeval', $request->type);
                })
                ->when($request->time != null, function ($query) use ($request) {
                    $startTime = $request->time . ':00';
                    return $query->whereRaw("TIME(checkins.time) >= ?", [$startTime]);
                })
                ->when($fromDate && $toDate, function ($query) use ($fromDate, $toDate) {
                    $nextDay = date('Y-m-d', strtotime($toDate . ' +1 day'));
                    return $query->whereBetween('checkins.created_at', [$fromDate, $nextDay]);
                })
                ->when($request->client_id != 0, function ($query) use ($request) {
                    return $query->where('checkins.client_id', $request->client_id);
                })
                ->when($request->assignment_id != 0, function ($query) use ($request) {
                    return $query->where('checkins.assignment_id', $request->assignment_id);
                });

            if ($partnerid) {
                $query->where(function ($q) use ($partnerid) {
                    $q->where('assignmentmappings.leadpartner', $partnerid)
                        ->orWhereNull('assignmentmappings.leadpartner');
                });
            }

            $query->select(
                'checkins.created_at',
                'checkins.time',
                'teammembers.team_member',
                'checkins.checkin_from',
                'checkins.typeval',
                'clients.client_name',
                'assignments.assignment_name',
                'checkins.assignment_id',
                'checkins.place',
                'checkins.latitude',
                'checkins.longitude',
                'teampartner.team_member as teampartner'
            );

            if ($request->filled('init') && (int) $request->init === 1) {
                $query->whereRaw('1 = 0');
            }

            if (!empty($request->search)) {
                $search = $request->search;
                $query->where(function ($q) use ($search) {
                    $q->where('teammembers.team_member', 'LIKE', "%{$search}%")
                        ->orWhere('teampartner.team_member', 'LIKE', "%{$search}%")
                        ->orWhere('checkins.checkin_from', 'LIKE', "%{$search}%")
                        ->orWhere('checkins.typeval', 'LIKE', "%{$search}%")
                        ->orWhere('clients.client_name', 'LIKE', "%{$search}%")
                        ->orWhere('assignments.assignment_name', 'LIKE', "%{$search}%")
                        ->orWhere('checkins.assignment_id', 'LIKE', "%{$search}%")
                        ->orWhere('checkins.place', 'LIKE', "%{$search}%");
                });
            }

            $allowedSorts = [
                'created_at' => 'checkins.created_at',
                'time' => 'checkins.time',
                'team_member' => 'teammembers.team_member',
                'teampartner' => 'teampartner.team_member',
                'checkin_from' => 'checkins.checkin_from',
                'typeval' => 'checkins.typeval',
                'client_name' => 'clients.client_name',
                'assignment_name' => 'assignments.assignment_name',
                'place' => 'checkins.place',
            ];

            if (!empty($request->sortColumn) && isset($allowedSorts[$request->sortColumn])) {
                $query->orderBy($allowedSorts[$request->sortColumn], $request->sortDirection ?? 'desc');
            } else {
                $query->orderBy('checkins.id', 'DESC');
            }

            $records = $query->paginate($request->perPage ?? 25);
            $datatable = view('backEnd.check-In.checkinreportdatatable', compact('records'))->render();

            return response()->json([
                'count' => $records->total(),
                'status' => 200,
                'msg' => 'Data loaded',
                'data' => $datatable,
                'paginationInfo' => getPaginationInfo($records),
            ]);
        }
    }
	
	
	
	
	
	
