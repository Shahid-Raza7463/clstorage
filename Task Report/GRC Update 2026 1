<script>
    document.addEventListener('DOMContentLoaded', () => {
        let seriesData = [];
        let seriesLabels = [];
        let legendLabels = []; // To store labels for the legend (without "Actionable")

        // Define your custom color mapping for specific labels
        const customColorMapping = {
            "Planned": "#2a9d8f",
            "In progress": "#aff4c6",
            "Draft report": "#f4a261",
            "Completed": "#e76f51",
            // Add more label-color pairs as needed
        };

        // Default color in case a label is not found in the mapping
        const defaultColor = "#CCCCCC";

        @foreach ($data as $key => $value)
            seriesData.push(Number({{ $value }})); // Ensure value is treated as a number
            seriesLabels.push("{{ $key }}"); // Use "Actionable" for chart labels
            legendLabels.push("Actionable<br>{{ $key }}"); // Use only $key for the legend
        @endforeach

        // Calculate total for percentages
        const total = seriesData.reduce((acc, value) => acc + value, 0);
        // Generate chart colors based on custom mapping
        const chartColors = seriesLabels.map(label => customColorMapping[label] || defaultColor);

        const customTooltip = {
            y: {
                formatter: (value, {
                    seriesIndex
                }) => {
                    const percentage = ((value / total) * 100).toFixed(1); // Calculate percentage
                    return `${value} (${percentage}%)`; // Format as "value (percentage%)"
                },
            },
        };

        const pieChartOptions = {
            series: seriesData,
            chart: {
                height: 350,
                type: 'pie',
                toolbar: {
                    show: true, // Remove toolbar (download menu) as per the requirement
                },
            },
            colors: chartColors, // Use custom colors
            legend: {
                position: 'bottom',
                offsetY: 5,
                labels: {
                    useSeriesColors: true, // Ensure the legend uses the same colors as the chart
                },
                markers: {
                    width: 10, // Adjust the width of the legend markers
                    height: 10, // Adjust the height of the legend markers
                },
            },
            labels: seriesLabels, // Use the labels with "Actionable"
            tooltip: customTooltip,
            plotOptions: {
                pie: {
                    expandOnClick: false, // Disable expanding the pie chart on click
                },
            },
            states: {
                hover: {
                    filter: 'none', // Disable hover effect (prevent color change on hover)
                },
            },
        };

        // Initialize and render the chart
        const pieChart = new ApexCharts(document.querySelector("#actionablestatusPieChart"), pieChartOptions);
        setTimeout(() => {
            pieChart.render();
        }, 100);

        // Store chart instance for future reference
        window.chartInstances = {
            ...window.chartInstances,
            actionablestatusPieChart: pieChart,
        };
    });
</script>








