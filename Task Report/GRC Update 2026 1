  public function SelfAssignmentDashboard($request)
    {
        $dashboardURL = $this->getDashboardUrl();
        if ($dashboardURL != route('admin.overviewdashboard')) {
            return redirect($dashboardURL);
        }

        $counts = $this->getCounts($request);
        $filters = $this->getFilters();
        $charts = $this->getCharts($request);
        $observationStatus = $this->observationStatus($request);
        // return $observationStatus;
        $observationstatuslist = $this->observationStatus($request);
        $actionablesStatus = $this->UpcomingActionable($request);
        $overdueactionable = $this->actionableStatus($request);
        $actionableStatusList = $this->actionableStatus($request);
        $actionableList = $this->actionableStatus($request);
        $processwiseObservationAgeing = $this->processwiseObservationAgeing($request);
        $ageingCounts = $processwiseObservationAgeing['ageingCounts'];
        $totals = $processwiseObservationAgeing['totals'];

        $issueStatus = getWorkflowStatus('observation');

        // Handle AJAX requests
        if ($request->isMethod('post')) {
            $tables = [
                'observationStatus' => view('dashboard_reports.partials.observation_status', compact('observationStatus'))->render(),
                'observationstatuslist' => view('dashboard_reports.partials.observation_status_list', compact('observationstatuslist'))->render(),
                'actionablesStatus' => view('dashboard_reports.partials.actionable_status', compact('actionablesStatus'))->render(),
                'overdueactionable' => view('dashboard_reports.partials.overdueactionable', compact('overdueactionable'))->render(),
                'actionableStatusList' => view('dashboard_reports.partials.actionable_status_list', compact('actionableStatusList'))->render(),
                'actionableList' => view('dashboard_reports.partials.actionable_list', compact('actionableList'))->render(),
                'ageingCounts' => view('dashboard_reports.partials.processwise_observation_ageing', compact('ageingCounts', 'totals'))->render(),

            ];
            //  dd($tables);
            return response()->json([
                'charts' => $charts,
                'counts' => $counts,
                'tables' => $tables,
            ]);
        }
        // dd($charts);
        // For GET requests, load the main dashboard view
        return view('newoverviewdashboard.selfassignment', compact(

            'issueStatus',
            'charts',
            'counts',
            'filters',
            'observationStatus',
            'actionablesStatus',
            'observationstatuslist',
            'overdueactionable',
            'actionableStatusList',
            'actionableList',
            'ageingCounts',
            'totals'
        ));
    }
	







